import java.util.Random;
import java.util.Scanner;

public class HangmanConsole {

    private static final String[] WORDS = {
        "java", "code", "game", "swing", "project", "simple", "beginner"
    };
    private static final int MAX_WRONG_GUESSES = 6;

    private String secretWord;
    private StringBuilder displayedWord;
    private int wrongGuesses;

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        HangmanConsole game = new HangmanConsole();
        String playAgain;

        do {
            game.startGame(sc);
            System.out.print("Do you want to play again? (yes/no): ");
            playAgain = sc.nextLine().trim().toLowerCase();
        } while (playAgain.equals("yes"));

        System.out.println("Thanks for playing!");
        sc.close();
    }

    private void startGame(Scanner sc) {
        secretWord = WORDS[new Random().nextInt(WORDS.length)];
        wrongGuesses = 0;

        displayedWord = new StringBuilder();
        for (int i = 0; i < secretWord.length(); i++) {
            displayedWord.append("_");
        }

        while (wrongGuesses < MAX_WRONG_GUESSES && displayedWord.indexOf("_") != -1) {
            System.out.println("\nWord: " + spacedWord());
            System.out.println("Guesses left: " + (MAX_WRONG_GUESSES - wrongGuesses));
            System.out.print("Enter a letter: ");
            String input = sc.nextLine().toLowerCase();

            if (input.length() != 1 || !Character.isLetter(input.charAt(0))) {
                System.out.println("Invalid input. Please enter a single letter.");
                continue;
            }

            char guess = input.charAt(0);
            processGuess(guess);
        }

        if (displayedWord.indexOf("_") == -1) {
            System.out.println("\nWord: " + spacedWord());
            System.out.println("🎉 YOU WIN! Congratulations!");
        } else {
            System.out.println("\nGAME OVER! The word was: " + secretWord);
        }
    }

    private void processGuess(char letter) {
        boolean found = false;
        for (int i = 0; i < secretWord.length(); i++) {
            if (secretWord.charAt(i) == letter && displayedWord.charAt(i) == '_') {
                displayedWord.setCharAt(i, letter);
                found = true;
            }
        }

        if (!found) {
            wrongGuesses++;
            System.out.println("❌ Wrong guess!");
        } else {
            System.out.println("✅ Correct guess!");
        }
    }

    private String spacedWord() {
        return displayedWord.toString().replace("", " ").trim();
    }
}
